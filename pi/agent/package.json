{
  "name": "dotfiles-pi-extensions",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "node scripts/sync-pi-dependencies.mjs --check && npm test && tsc --noEmit",
    "eval:background-monitor": "node --experimental-strip-types evals/background-monitor/run.ts",
    "sync:pi": "node scripts/sync-pi-dependencies.mjs",
    "test": "node --experimental-strip-types --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.80.10",
    "typebox": "1.1.38"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "typescript": "5.9.3"
  }
}
